{
  "id": "example",
  "name": "两数之和",
  "description": "给定两个数 a 和 b，计算它们的和并存入变量 ans",
  "timeLimit": 5000,
  "stepLimit": 100000,
  "testCases": [
    {
      "input": { "a": 3, "b": 5 },
      "output": { "ans": 8 }
    },
    {
      "input": { "a": 10, "b": 20 },
      "output": { "ans": 30 }
    },
    {
      "input": { "a": -1, "b": 1 },
      "output": { "ans": 0 }
    },
    {
      "input": { "a": 100, "b": 200 },
      "output": { "ans": 300 }
    }
  ]
}
